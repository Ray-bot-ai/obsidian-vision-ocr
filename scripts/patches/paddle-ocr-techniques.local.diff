+def _retry_after_seconds(response: requests.Response) -> float:
+    """解析 429/503 的 Retry-After 头（秒），无则 0。"""
+    val = response.headers.get("Retry-After")
+    if not val:
+        return 0.0
+    try:
+        return float(val)
+    except ValueError:
+        return 0.0
+
+
+def _submit_jobid(response: requests.Response) -> str | None:
+    """从提交响应里取 jobId，没有则 None。"""
+    try:
+        data = response.json().get("data")
+    except ValueError:
+        return None
+    if isinstance(data, dict):
+        return data.get("jobId")
+    return None
+
+
+def _is_retryable_body(response: requests.Response) -> bool:
+    """业务层「队列已满/请稍后重试」等：HTTP 200 但应退避重试。"""
+    try:
+        body = response.json()
+    except ValueError:
+        return False
+    if not isinstance(body, dict):
+        return False
+    if body.get("code") in RETRYABLE_BODY_CODES:
+        return True
+    msg = str(body.get("msg", ""))
+    return any(k in msg for k in RETRYABLE_BODY_KEYWORDS)
+
